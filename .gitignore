.env
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
mlruns/
results/*/checkpoints/
# HuggingFace Trainer intermediate checkpoints (optimizer/scheduler/rng state) —
# bulky and not needed to serve; only the deployable best_model.pt is committed.
results/**/checkpoint-*/
results/**/*.onnx
results/**/*.bin
results/**/*.safetensors
# Trained weights (best_model.pt, retrieval_index.pt) are too large for GitHub
# LFS (1GB free quota); they are served from the Hugging Face Space/Hub instead.
# The small JSON/CSV result files ARE committed so the README tables reproduce
# from tracked data.
results/**/*.pt
results/**/*.pth
*.db
*.log
.ipynb_checkpoints/
wandb/
lightning_logs/

# Local-only planning/scratch docs — keep on disk, never commit
docs/superpowers/
AUDIT.md
PLAN.md
