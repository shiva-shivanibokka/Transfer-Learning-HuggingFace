# ── HuggingFace ───────────────────────────────────────────────
# Optional: only needed to PUSH trained models to the Hub.
HF_TOKEN=

# ── MLflow ────────────────────────────────────────────────────
# Local file store by default; set to a remote URI to share runs.
MLFLOW_TRACKING_URI=mlruns

# ── Logging ───────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
