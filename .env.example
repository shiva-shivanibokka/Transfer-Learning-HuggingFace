# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required to push trained models to the Hub
HF_TOKEN=

# ── MLflow ────────────────────────────────────────────────────────────────────
# Leave default to store runs locally in ./mlruns
# Change to a remote URI for team sharing: http://mlflow-server:5000
MLFLOW_TRACKING_URI=mlruns

# ── Training ──────────────────────────────────────────────────────────────────
# Override default models used in training
AGENT_MODEL=claude-sonnet-4-5
AGENTLESS_MODEL=claude-sonnet-4-5

# ── Hardware ──────────────────────────────────────────────────────────────────
# Set to 0 for CPU-only, or a GPU index
CUDA_VISIBLE_DEVICES=0
